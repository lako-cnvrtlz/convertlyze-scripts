<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { width: 100%; height: 100%; overflow: hidden; background: #f5f7fa; }
  canvas { display: block; width: 100%; height: 100%; }
</style>
</head>
<body>
<canvas id="c"></canvas>
<script>
(function() {
  var canvas = document.getElementById('c');
  var ctx    = canvas.getContext('2d');

  var W, H;
  var nodes  = [];
  var mouse  = { x: -999, y: -999 };

  var CONFIG = {
    nodeCount:       90,
    maxDist:         160,
    nodeRadius:      2.8,
    nodeRadiusLarge: 4.5,
    largeEvery:      7,
    speed:           0.35,
    color:           '15,158,148',
    bgColor:         '#f5f7fa',
    mouseRadius:     140,
    lineAlphaMax:    0.18,
    dotAlphaBase:    0.45,
    dotAlphaLarge:   0.75,
    vignetteX:       0.35,
    vignetteY:       0.50,
    vignetteR:       0.55,
  };

  function resize() {
    W = canvas.width  = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
    nodes.forEach(function(n) {
      if (n.x > W) n.x = Math.random() * W;
      if (n.y > H) n.y = Math.random() * H;
    });
  }

  function createNode(i) {
    var large = (i % CONFIG.largeEvery === 0);
    return {
      x:   Math.random() * (W || window.innerWidth),
      y:   Math.random() * (H || window.innerHeight),
      vx:  (Math.random() - 0.5) * CONFIG.speed,
      vy:  (Math.random() - 0.5) * CONFIG.speed,
      r:   large ? CONFIG.nodeRadiusLarge : CONFIG.nodeRadius,
      a:   large ? CONFIG.dotAlphaLarge   : CONFIG.dotAlphaBase,
      large: large,
      pulse: Math.random() * Math.PI * 2,
      pulseSpeed: 0.018 + Math.random() * 0.012,
    };
  }

  function init() {
    resize();
    nodes = [];
    for (var i = 0; i < CONFIG.nodeCount; i++) {
      nodes.push(createNode(i));
    }
  }

  function drawVignette() {
    var grd = ctx.createRadialGradient(
      W * CONFIG.vignetteX, H * CONFIG.vignetteY, 0,
      W * CONFIG.vignetteX, H * CONFIG.vignetteY, Math.max(W, H) * CONFIG.vignetteR
    );
    grd.addColorStop(0,    'rgba(245,247,250,0.88)');
    grd.addColorStop(0.45, 'rgba(245,247,250,0.50)');
    grd.addColorStop(1,    'rgba(245,247,250,0)');
    ctx.fillStyle = grd;
    ctx.fillRect(0, 0, W, H);
  }

  function tick() {
    ctx.clearRect(0, 0, W, H);

    ctx.fillStyle = CONFIG.bgColor;
    ctx.fillRect(0, 0, W, H);

    nodes.forEach(function(n) {
      n.pulse += n.pulseSpeed;
      n.x += n.vx;
      n.y += n.vy;
      if (n.x < 0)  { n.x = 0;  n.vx *= -1; }
      if (n.x > W)  { n.x = W;  n.vx *= -1; }
      if (n.y < 0)  { n.y = 0;  n.vy *= -1; }
      if (n.y > H)  { n.y = H;  n.vy *= -1; }
    });

    // connections
    for (var i = 0; i < nodes.length; i++) {
      for (var j = i + 1; j < nodes.length; j++) {
        var a = nodes[i];
        var b = nodes[j];
        var dx = a.x - b.x;
        var dy = a.y - b.y;
        var dist = Math.sqrt(dx*dx + dy*dy);

        if (dist < CONFIG.maxDist) {
          var alpha = CONFIG.lineAlphaMax * (1 - dist / CONFIG.maxDist);
          var mx = (a.x + b.x) / 2 - mouse.x;
          var my = (a.y + b.y) / 2 - mouse.y;
          var mouseDist = Math.sqrt(mx*mx + my*my);
          if (mouseDist < CONFIG.mouseRadius) {
            alpha *= 1 + 1.5 * (1 - mouseDist / CONFIG.mouseRadius);
          }
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.strokeStyle = 'rgba(' + CONFIG.color + ',' + alpha + ')';
          ctx.lineWidth = 0.8;
          ctx.stroke();
        }
      }
    }

    // nodes
    nodes.forEach(function(n) {
      var pulse = 0.75 + 0.25 * Math.sin(n.pulse);
      var r = n.r * pulse;
      var a = n.a * pulse;

      var mdx = n.x - mouse.x;
      var mdy = n.y - mouse.y;
      var md  = Math.sqrt(mdx*mdx + mdy*mdy);
      if (md < CONFIG.mouseRadius) {
        var boost = 1 - md / CONFIG.mouseRadius;
        a = Math.min(1, a + boost * 0.5);
        r = r + boost * 2;
      }

      if (n.large) {
        ctx.beginPath();
        ctx.arc(n.x, n.y, r + 5, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + CONFIG.color + ',' + (a * 0.15) + ')';
        ctx.fill();
        ctx.beginPath();
        ctx.arc(n.x, n.y, r + 2, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + CONFIG.color + ',' + (a * 0.30) + ')';
        ctx.fill();
      }

      ctx.beginPath();
      ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(' + CONFIG.color + ',' + a + ')';
      ctx.fill();
    });

    drawVignette();
    requestAnimationFrame(tick);
  }

  window.addEventListener('mousemove', function(e) {
    var rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
  });
  window.addEventListener('mouseleave', function() {
    mouse.x = -999; mouse.y = -999;
  });
  window.addEventListener('resize', resize);

  init();
  tick();
})();
</script>
</body>
</html>
