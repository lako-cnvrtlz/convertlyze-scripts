// ── Deps-Prüfung mit Retry ────────────────────────────────────────────────────

async function waitForDeps(maxAttempts = 30) {
  for (let i = 0; i < maxAttempts; i++) {
    if (
      window.$memberstackDom &&
      typeof window.supabase?.from === 'function'
    ) return true;
    await sleep(300);
  }
  return false;
}

