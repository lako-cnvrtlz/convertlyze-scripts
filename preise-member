function getParam(key) {
  return new URLSearchParams(window.location.search).get(key);
}

function sleep(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

function revealContent() {
  const heroBlock = document.querySelector('.content_hero');
